<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ERP_APP.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:layout="clr-namespace:ERP_APP.Layout"
        xmlns:pages="clr-namespace:ERP_APP.Pages"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ERP_APP.Views.DashBoard"
        x:DataType="vm:DashBoardViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ERP_APP"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid ColumnDefinitions="324, *">
        <!-- Sidebar layout on the left -->
        <layout:Sidebar Grid.Column="0"/>

        <!-- Main layout on the right -->
        <layout:Main Grid.Column="1"/>
    </Grid>

</Window>